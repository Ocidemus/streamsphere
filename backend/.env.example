# StreamSphere Environment Configuration

PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/streamsphere
JWT_SECRET=streamsphere_super_secret_key

# AWS S3 / Cloudflare R2 Object Storage Config (Optional, falls back to local uploads if empty)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=auto
AWS_S3_BUCKET=your_s3_bucket_name

# Custom S3-compatible Endpoint (Uncomment/Fill for Cloudflare R2)
# AWS_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# Public CDN / Bucket Distribution URL (Optional, rewrites storage URLs to CDN domains)
PUBLIC_URL_PREFIX=https://pub-xxxxxx.r2.dev
CLOUDFRONT_URL=

